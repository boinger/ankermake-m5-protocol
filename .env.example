# ============================================================
# ankerctl – Environment Variables
# ============================================================
# Copy this file to .env and adjust the values.
# Docker Compose will pick it up automatically via env_file.
# ============================================================

# --- Server ---------------------------------------------------
# IP address the web server binds to (default: 127.0.0.1)
FLASK_HOST=127.0.0.1

# Port the web server listens on (default: 4470)
FLASK_PORT=4470

# --- Upload ---------------------------------------------------
# Maximum upload size in megabytes (default: 2048)
#UPLOAD_MAX_MB=2048

# Upload speed to printer in Mbit/s (choices: 2, 4, 6, 8)
#UPLOAD_RATE_MBPS=2

# --- Security -------------------------------------------------
# API key for write-operation authentication.
# Leave unset to disable authentication (default behavior).
#ANKERCTL_API_KEY=your-secret-key-here

# --- UI Feature Flags ----------------------------------------
# Show Pause/Resume/Stop print buttons (experimental, may not work).
# Set to any non-empty value to enable; leave unset to hide.
#ANKERCTL_PRINT_CONTROLS=1

# --- Print History -------------------------------------------
# Number of days to keep history entries (default: 90)
#PRINT_HISTORY_RETENTION_DAYS=90

# Maximum number of history entries to keep (default: 500)
#PRINT_HISTORY_MAX_ENTRIES=500

# --- Timelapse ------------------------------------------------
# Enable automatic timelapse capture during prints (requires ffmpeg)
#TIMELAPSE_ENABLED=false

# Seconds between snapshot captures (default: 30)
#TIMELAPSE_INTERVAL_SEC=30

# Maximum number of timelapse videos to keep (default: 10)
#TIMELAPSE_MAX_VIDEOS=10

# Save assembled videos persistently (default: true)
#TIMELAPSE_SAVE_PERSISTENT=true

# Directory to store timelapse videos (default: /captures)
#TIMELAPSE_CAPTURES_DIR=/captures

# --- Home Assistant MQTT Discovery ----------------------------
# Publishes printer state to HA via MQTT Discovery protocol.
# Requires an MQTT broker accessible from ankerctl (e.g. Mosquitto).

#HA_MQTT_ENABLED=false
#HA_MQTT_HOST=localhost
#HA_MQTT_PORT=1883
#HA_MQTT_USER=
#HA_MQTT_PASSWORD=
#HA_MQTT_DISCOVERY_PREFIX=homeassistant
#HA_MQTT_TOPIC_PREFIX=ankerctl

# --- Apprise Notifications -----------------------------------
# Requires an external Apprise API server.
# See: https://github.com/caronc/apprise-api

#APPRISE_ENABLED=false
#APPRISE_SERVER_URL=http://apprise:8000
#APPRISE_KEY=ankerctl
#APPRISE_TAG=

# Event toggles
#APPRISE_EVENT_PRINT_STARTED=true
#APPRISE_EVENT_PRINT_FINISHED=true
#APPRISE_EVENT_PRINT_FAILED=true
#APPRISE_EVENT_GCODE_UPLOADED=true
#APPRISE_EVENT_PRINT_PROGRESS=true

# Progress settings
#APPRISE_PROGRESS_INTERVAL=25
#APPRISE_PROGRESS_INCLUDE_IMAGE=false
#APPRISE_PROGRESS_MAX=0

# Snapshot settings
#APPRISE_SNAPSHOT_QUALITY=hd
#APPRISE_SNAPSHOT_FALLBACK=true
#APPRISE_SNAPSHOT_LIGHT=false
